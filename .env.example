# ============================================================
# RaccBuddy — Environment Configuration Template
# Copy this file to .env and fill in your values.
# ============================================================

# ---- Telegram ---------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
OWNER_TELEGRAM_ID=0  # Set after first /start to lock the bot to you

# ---- WhatsApp (optional) ----------------------------------------
OWNER_WHATSAPP_NUMBER=  # e.g. 15551234567 (no + or spaces)

# ---- Database ---------------------------------------------------
# For local development:
DATABASE_URL=postgresql+asyncpg://raccbuddy:raccbuddy@localhost:5432/raccbuddy
# For Docker Compose, DATABASE_URL is set automatically in docker-compose.yml

# ---- LLM Provider -----------------------------------------------
LLM_PROVIDER=ollama          # ollama | xai
EMBEDDING_PROVIDER=ollama    # ollama | xai (ollama recommended for privacy)

# ---- Ollama (local) ---------------------------------------------
# For local development:
OLLAMA_BASE_URL=http://localhost:11434
# For Docker Compose: http://host.docker.internal:11434 (set in docker-compose.yml)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---- xAI / Grok (optional cloud provider) -----------------------
XAI_API_KEY=your-xai-key-here
XAI_MODEL=grok-4-1-fast-reasoning
XAI_ENABLE_BUILTIN_TOOLS=false   # set true ONLY if you want Grok's real-time search/code/X tools

# ---- Context Window ---------------------------------------------
# How many tokens Ollama allocates for the full context (num_ctx).
# Default 30000 is suitable for models with 32k+ context length.
# Lower to 8192 for small models like llama3.2:3b on limited RAM.
MAX_CONTEXT_TOKENS=30000

# ---- REST API Security ------------------------------------------
# Secret key for the X-API-Key header on POST /api/messages.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable auth check (not recommended for production).
API_SECRET_KEY=

# ---- Nudges -----------------------------------------------------
NUDGE_CHECK_INTERVAL_MINUTES=60

# ---- Agentic Proactive Core (opt-in) ----------------------------
AGENTIC_ENABLED=false
CHECKPOINTER_BACKEND=postgres      # postgres | sqlite
MAX_CYCLE_TOKENS=8192               # Token budget per agentic cycle
AGENTIC_CYCLE_INTERVAL_MINUTES=30   # How often the agentic cycle runs

# ---- Langfuse Tracing (optional, self-hosted) -------------------
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ---- Prometheus Metrics (optional) ------------------------------
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ---- Memory -----------------------------------------------------
OWNER_MEMORY_RETENTION_DAYS=90
MAX_SUMMARY_WORDS=150
