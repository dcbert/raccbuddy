# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
OWNER_TELEGRAM_ID=0  # Set after first /start to lock the bot

# WhatsApp
OWNER_WHATSAPP_NUMBER=  # Your WhatsApp number for owner message recognition (optional)

# Database
# For local development:
DATABASE_URL=postgresql+asyncpg://raccbuddy:raccbuddy@localhost:5432/raccbuddy
# For Docker: use 'db' as hostname (automatically set in docker-compose.yml)

# LLM Provider Selection (ollama, xai, etc.)
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Ollama
# For local development:
OLLAMA_BASE_URL=http://localhost:11434
# For Docker: use http://host.docker.internal:11434 (automatically set in docker-compose.yml)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# xAI (optional, if using LLM_PROVIDER=xai)
XAI_API_KEY=your-key-here
XAI_MODEL=grok-3-mini

# Token limits
MAX_CONTEXT_TOKENS=2000
MAX_SUMMARY_WORDS=150

# Nudges
NUDGE_CHECK_INTERVAL_MINUTES=60

# Memory
OWNER_MEMORY_RETENTION_DAYS=90

